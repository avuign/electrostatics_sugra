Cell[BoxData[{
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Log", "[", " ", 
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{
        SuperscriptBox["2", "16"], 
        SuperscriptBox["\[Pi]", 
         RowBox[{"29", "/", "2"}]]}], "3"], " ", 
      RowBox[{"(", 
       FractionBox[
        RowBox[{
         RowBox[{"128", " ", 
          SqrtBox[
           RowBox[{"3", " ", "\[Pi]"}]], " ", 
          RowBox[{"(", 
           RowBox[{"4294967296", "+", 
            RowBox[{"81", " ", 
             SuperscriptBox["\[CapitalOmega]", "4"], " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"-", "20480"}], "+", 
               RowBox[{"3", " ", 
                SuperscriptBox["\[CapitalOmega]", "4"]}]}], ")"}]}]}], 
           ")"}]}], "+", 
         RowBox[{"9", " ", 
          SuperscriptBox["\[ExponentialE]", 
           FractionBox[
            RowBox[{"3", " ", 
             SuperscriptBox["\[CapitalOmega]", "4"]}], "16384"]], " ", 
          "\[Pi]", " ", 
          SuperscriptBox["\[CapitalOmega]", "2"], " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1635778560", "+", 
               RowBox[{"331776", " ", 
                SuperscriptBox["\[CapitalOmega]", "4"]}], "-", 
               RowBox[{"81", " ", 
                SuperscriptBox["\[CapitalOmega]", "8"]}]}], ")"}], " ", 
             RowBox[{"Erfc", "[", 
              FractionBox[
               RowBox[{
                SqrtBox["3"], " ", 
                SuperscriptBox["\[CapitalOmega]", "2"]}], "128"], "]"}]}], 
            "-", 
            RowBox[{"1048576000", " ", 
             SuperscriptBox["\[ExponentialE]", 
              FractionBox[
               RowBox[{"3", " ", 
                SuperscriptBox["\[CapitalOmega]", "4"]}], "2048"]], " ", 
             RowBox[{"Erfc", "[", 
              FractionBox[
               RowBox[{"3", " ", 
                SqrtBox["3"], " ", 
                SuperscriptBox["\[CapitalOmega]", "2"]}], "128"], "]"}]}]}], 
           ")"}]}]}], 
        RowBox[{"12884901888", " ", 
         SuperscriptBox["\[CapitalOmega]", "2"]}]], ")"}]}], "+", 
     RowBox[{
      SuperscriptBox["5", "3"], 
      SuperscriptBox["2", "8"], 
      SuperscriptBox["\[Pi]", 
       RowBox[{"31", "/", "2"}]], 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        FractionBox["27", 
         SuperscriptBox["2", "14"]], 
        SuperscriptBox["\[CapitalOmega]", "4"]}]]}]}], "]"}], ",", 
